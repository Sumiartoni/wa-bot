# ========================
# WhatsApp Cloud API (Official)
# ========================
# Dari Meta Developer Console > WhatsApp > API Setup
WA_PHONE_NUMBER_ID=your_phone_number_id
WA_ACCESS_TOKEN=your_access_token
WA_VERIFY_TOKEN=mywabot2026

# ========================
# GROQ AI API Key
# ========================
# Dari https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========================
# Admin Dashboard Login
# ========================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT Secret (random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server Port
PORT=3000

# ========================
# AI Settings
# ========================
AI_MODEL=llama-3.3-70b-versatile
AI_SYSTEM_PROMPT=Kamu adalah asisten AI yang ramah dan membantu. Jawab dalam bahasa yang sama dengan pengguna. Berikan jawaban yang ringkas dan informatif.
