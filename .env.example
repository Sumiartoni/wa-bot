# GROQ AI API Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin Dashboard Login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT Secret for auth tokens
JWT_SECRET=your-super-secret-jwt-key-change-this

